pipeline {
    agent any

    stages {

        stage('Verify Environment') {
            steps {
                echo '=== Jenkins Environment ==='

                sh '''
                    set -e

                    echo "User:"
                    whoami

                    echo ""
                    echo "Workspace:"
                    pwd

                    echo ""
                    echo "Git:"
                    git --version

                    echo ""
                    echo "Python:"
                    python3 --version

                    echo ""
                    echo "Docker:"
                    docker --version
                '''
            }
        }

        stage('Checkout Application') {
            steps {
                dir('application') {
                    git branch: 'main',
                        url: 'https://github.com/ruthwikshri1121-stack/devops-asset-inventory.git'
                }
            }
        }

        stage('Verify Workspace') {
            steps {
                sh '''
                    set -e

                    echo "===== Infrastructure Repository ====="

                    pwd

                    ls -la

                    echo ""

                    echo "===== Application Repository ====="

                    ls -la application
                '''
            }
        }

        stage('Install Python Dependencies') {
            steps {
                dir('application') {
                    sh '''
                        set -e

                        echo "===== Creating Python Virtual Environment ====="

                        python3 -m venv .venv

                        . .venv/bin/activate

                        python -m pip install --upgrade pip

                        pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Run Unit Tests') {
            steps {
                sh '''
                    set -e

                    echo "===== Running Unit Tests ====="

                    . application/.venv/bin/activate

                    export APP_ENV=testing

                    python scripts/run_tests.py \
                        --app-repo application
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    set -e

                    echo "===== Building Docker Image ====="

                    python3 scripts/build_image.py \
                        --app-repo application
                '''
            }
        }

        stage('Verify Docker Image') {
            steps {
                sh '''
                    set -e

                    echo "===== Available Docker Images ====="

                    docker images
                '''
            }
        }

    }

    post {

        success {
            echo 'Pipeline completed successfully.'
        }

        failure {
            echo 'Pipeline failed. Check the console output for details.'
        }

        always {
            echo 'Pipeline execution finished.'
        }

    }
}