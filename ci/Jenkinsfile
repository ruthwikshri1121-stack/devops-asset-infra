pipeline {
    agent any

    environment {
        APP_ENV = "testing"
        APP_NAME = "devops-asset-inventory"
        IMAGE_VERSION = ""
    }

    stages {

        stage('Verify Environment') {
            steps {
                echo '=== Jenkins Environment ==='

                sh '''
                    set -e

                    echo "===== Environment ====="

                    echo "User:"
                    whoami

                    echo ""

                    echo "Workspace:"
                    pwd

                    echo ""

                    echo "Git:"
                    git --version

                    echo ""

                    echo "Python:"
                    python3 --version

                    echo ""

                    echo "Docker:"
                    docker --version
                '''
            }
        }

        stage('Checkout Application') {
            steps {
                dir('application') {
                    git(
                        branch: 'main',
                        url: 'https://github.com/ruthwikshri1121-stack/devops-asset-inventory.git'
                    )
                }
            }
        }

        stage('Verify Workspace') {
            steps {
                sh '''
                    set -e

                    echo "===== Infrastructure Repository ====="

                    pwd
                    ls -la

                    echo ""

                    echo "===== Application Repository ====="

                    ls -la application
                '''
            }
        }

        stage('Install Python Dependencies') {
            steps {
                dir('application') {
                    sh '''
                        set -e

                        echo "===== Creating Python Virtual Environment ====="

                        python3 -m venv .venv

                        . .venv/bin/activate

                        python -m pip install --upgrade pip

                        pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Generate Version') {
            steps {
                script {

                    def version = sh(
                        script: '''
                            set -e

                            . application/.venv/bin/activate

                            python scripts/version.py \
                                --images images.json \
                                --application ${APP_NAME}
                        ''',
                        returnStdout: true
                    ).trim()

                    echo "Raw version output: '${version}'"

                    if (!version) {
                        error("Version generation failed. No version was returned.")
                    }

                    env.IMAGE_VERSION = version

                    echo "Generated Image Version: ${env.IMAGE_VERSION}"
                }
            }
        }

        stage('Run Unit Tests') {
            steps {
                sh '''
                    set -e

                    echo "===== Running Unit Tests ====="

                    . application/.venv/bin/activate

                    export APP_ENV=${APP_ENV}

                    python scripts/run_tests.py \
                        --app-repo application
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    set -e

                    echo "===== Building Docker Image ====="

                    . application/.venv/bin/activate

                    python scripts/build_image.py \
                        --app-repo application \
                        --version ${IMAGE_VERSION}
                '''
            }
        }

        stage('Verify Docker Image') {
            steps {
                sh '''
                    set -e

                    echo "===== Available Docker Images ====="

                    docker images
                '''
            }
        }

        stage('Update Build Metadata') {
            steps {
                sh '''
                    set -e

                    echo "===== Updating images.json ====="

                    . application/.venv/bin/activate

                    python scripts/update_images.py \
                        --images images.json \
                        --application ${APP_NAME} \
                        --version ${IMAGE_VERSION} \
                        --build-number ${BUILD_NUMBER}
                '''
            }
        }

        stage('Push Docker Image') {
            when {
                expression {
                    return fileExists('images.json')
                }
            }

            steps {
                sh '''
                    set -e

                    echo "===== Pushing Docker Image ====="

                    . application/.venv/bin/activate

                    python scripts/push_image.py \
                        --app-repo application \
                        --version ${IMAGE_VERSION}
                '''
            }
        }
    }

    post {

        success {
            echo '========================================'
            echo 'Pipeline completed successfully.'
            echo "Application : ${APP_NAME}"
            echo "Version     : ${IMAGE_VERSION}"
            echo '========================================'
        }

        failure {
            echo '========================================'
            echo 'Pipeline failed.'
            echo 'Check the Jenkins console output.'
            echo '========================================'
        }

        always {
            echo 'Pipeline execution finished.'
        }
    }
}